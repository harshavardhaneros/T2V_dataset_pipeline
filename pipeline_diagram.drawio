<mxfile host="65bd71144e">
    <diagram id="indic-pipeline-v3" name="Indic Video Pipeline v3 (vLLM + Ray)">
        <mxGraphModel dx="1420" dy="850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                
                <!-- TITLE HEADER -->
                <mxCell id="title" value="INDIC VIDEO DATASET PIPELINE v3 — HIGH-THROUGHPUT ARCHITECTURE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;fontColor=#111111;" vertex="1" parent="1">
                    <mxGeometry x="40" y="20" width="1350" height="40" as="geometry"/>
                </mxCell>
                
                <!-- v3 HARDWARE INFRASTRUCTURE -->
                <mxCell id="env_box" value="H200 High-Performance Compute Mesh (8× GPU)" style="swimlane;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#F0F7FF;strokeColor=#0052A3;" vertex="1" parent="1">
                    <mxGeometry x="1080" y="100" width="360" height="420" as="geometry"/>
                </mxCell>
                <mxCell id="vllm_cluster" value="&lt;b&gt;vLLM Batch Engine (Data-Parallel Replicas)&lt;/b&gt;&lt;br/&gt;• TP Size: 1 per GPU | Replicas: 8 (8× H200)&lt;br/&gt;• Services: s5 (Classify), s8 (Caption)&lt;br/&gt;• Models: Qwen2.5-VL-7B / Gemma-4-31B-IT" style="text;html=1;strokeColor=#B33A3A;fillColor=#FFD2D2;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=12;html=1;spacingLeft=10;spacingTop=6;" vertex="1" parent="env_box">
                    <mxGeometry x="20" y="45" width="320" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="ray_cluster" value="&lt;b&gt;Ray Distributed Worker Mesh&lt;/b&gt;&lt;br/&gt;• Parallel Workers: 8 GPU Actors / 32 CPU Cores&lt;br/&gt;• Services: s6 (Verify), s7 (Actor), s9 (Quality)&lt;br/&gt;• Logic: Asynchronous task scheduling per clip" style="text;html=1;strokeColor=#228B22;fillColor=#D2F8D2;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=12;html=1;spacingLeft=10;spacingTop=6;" vertex="1" parent="env_box">
                    <mxGeometry x="20" y="135" width="320" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="cpu_heavy" value="&lt;b&gt;Legacy CPU / IO Workers&lt;/b&gt;&lt;br/&gt;• s1-s4 &amp; s10-s12: Single-threaded orchestrator&lt;br/&gt;• Mode: FFmpeg segmentation &amp; BK-Tree Dedup" style="text;html=1;strokeColor=#666666;fillColor=#EAEAEA;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=12;html=1;spacingLeft=10;spacingTop=6;" vertex="1" parent="env_box">
                    <mxGeometry x="20" y="225" width="320" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="two_phase" value="&lt;b&gt;Two-Phase Execution Strategy&lt;/b&gt;&lt;br/&gt;Necessary for v3-2GPU (logical cuda:0,1)&lt;br/&gt;Phase 1: s1 → s7 (Ray Mesh Load)&lt;br/&gt;Phase 2: s8 → s12 (vLLM Caption Load)&lt;br/&gt;Prevents CUDA process context memory leaks." style="text;html=1;strokeColor=#0052A3;fillColor=#DAE8FC;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;html=1;spacingLeft=10;spacingTop=6;" vertex="1" parent="env_box">
                    <mxGeometry x="20" y="300" width="320" height="100" as="geometry"/>
                </mxCell>

                <!-- MAIN WORKSPACE SWIMLANE -->
                <mxCell id="orchestrator" value="run_pipeline.py — v3 Distributed Orchestrator" style="swimlane;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#FFFAD2;strokeColor=#D6B656;startSize=30;" vertex="1" parent="1">
                    <mxGeometry x="40" y="100" width="660" height="1580" as="geometry"/>
                </mxCell>

                <!-- STAGES -->
                <mxCell id="s1" value="&lt;b&gt;s1: Extract Service&lt;/b&gt;&lt;br/&gt;• Engine: FFmpeg Stream Segmentation&lt;br/&gt;• Parallelism: Ray Parallel Frame Extraction (16 workers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="50" width="560" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="&lt;b&gt;s2: Dedup Service&lt;/b&gt;&lt;br/&gt;• Engine: pHash BK-Tree Matching&lt;br/&gt;• Parallelism: Ray Score-only Parallel Export (8 workers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="150" width="560" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="&lt;b&gt;s3: Band Removal&lt;/b&gt; | &lt;b&gt;s4: Watermark&lt;/b&gt;&lt;br/&gt;• Engine: Custom Pixel Matrix Structural Trimming&lt;br/&gt;• Action: Spatial crop box computation per record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="250" width="560" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="s5" value="&lt;b&gt;s5: Classify Service (vLLM Engine)&lt;/b&gt;&lt;br/&gt;• Model: Qwen2.5-VL-7B-Instruct&lt;br/&gt;• Throughput: Batched asynchronous inference (Batch size 16-24)&lt;br/&gt;• Hardware: Replicated across 8 GPUs (TP=1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD2D2;strokeColor=#B33A3A;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="350" width="560" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="s6" value="&lt;b&gt;s6: Verify Service (Ray Parallel)&lt;/b&gt;&lt;br/&gt;• Model: Gemma-3-4B-IT&lt;br/&gt;• Mode: Distributed Gemma-workers (8 Workers across cluster)&lt;br/&gt;• Logic: Cross-bucket VLM confirmation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D2F8D2;strokeColor=#228B22;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="460" width="560" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="s7" value="&lt;b&gt;s7: Actor Tagging (Ray Parallel)&lt;/b&gt;&lt;br/&gt;• Model: YOLOv12n-face + InsightFace-buffalo_l&lt;br/&gt;• Parallelism: 8 Concurrent Actor Tagging Workers&lt;br/&gt;• Database: 108 Cinematic Pre-baked Embeddings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D2E2F8;strokeColor=#3366CC;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="570" width="560" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="phase_boundary" value="&lt;b&gt;[ PHASE BOUNDARY: v3-2GPU CONTEXT RESTART POINT ]&lt;/b&gt;" style="text;html=1;strokeColor=#FF0000;fillColor=#FFE6E6;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="680" width="560" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="s8" value="&lt;b&gt;s8: Caption Service (vLLM High-Throughput)&lt;/b&gt;&lt;br/&gt;• Model: Gemma-4-31B-IT (0.19+ Engine) / Qwen2.5-VL-7B&lt;br/&gt;• Capability: Multi-frame Video Input | Prose Format Output&lt;br/&gt;• Strategy: 8× Data-Parallel Replicas | Async Batching" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD2D2;strokeColor=#B33A3A;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="730" width="560" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s9" value="&lt;b&gt;s9: Quality Scoring (Ray Parallel)&lt;/b&gt;&lt;br/&gt;• Model: CLIP (ViT-B-32) + GroundingDINO + DOVER (Motion/Aesthetic)&lt;br/&gt;• Workers: 8 Distributed GPU Scorers | 8 Motion Scrapers&lt;br/&gt;• Action: Compute Aesthetic/Technical scores per clip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D2F8D2;strokeColor=#228B22;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="850" width="560" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s10" value="&lt;b&gt;s10: Gate Service (Filtering)&lt;/b&gt;&lt;br/&gt;• Action: Eviction of records below aesthetic threshold&lt;br/&gt;• Source: pipeline_v3_vllm.yaml → thresholds.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="970" width="560" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="s11" value="&lt;b&gt;s11: Export Service&lt;/b&gt;&lt;br/&gt;• Action: Final high-aesthetic dataset packaging&lt;br/&gt;• Output: CSV + JSONL master rows (v3_outputs/&lt;video_id&gt;/)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="1070" width="560" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="s12" value="&lt;b&gt;s12: Report Service&lt;/b&gt;&lt;br/&gt;• Action: v3 Runtime Performance Aggregation&lt;br/&gt;• Output: pipeline_outputs/reports/runtime_summary.csv" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#AAAAAA;fontSize=12;align=left;spacingLeft=15;html=1;" vertex="1" parent="orchestrator">
                    <mxGeometry x="50" y="1170" width="560" height="80" as="geometry"/>
                </mxCell>

                <!-- DATA SYNC -->
